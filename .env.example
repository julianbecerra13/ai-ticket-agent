# ============================================================
# Configuración del servicio
# Copia este archivo como `.env` y completa con tus valores.
# ============================================================

# --- Base de datos (obligatorio) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tickets

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Clasificador ML ---
MODEL_PATH=src/ml/models/ticket_classifier.pkl

# ============================================================
# LLM — elige UNO de los tres bloques de abajo.
# Sin ninguno configurado, la API arranca en modo degradado:
#   - /tickets y /metrics funcionan (clasificador ML activo)
#   - /agent/decide responde 503 con mensaje claro
# ============================================================

# Opcional: fuerza un proveedor concreto (anthropic | openai | ollama)
# Si se omite, se detecta automáticamente el primero disponible.
# LLM_PROVIDER=anthropic

# ---- Opción 1: Anthropic Claude ----
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-opus-4-7

# ---- Opción 2: OpenAI ----
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# ---- Opción 3: Ollama local (gratis, requiere tener Ollama corriendo) ----
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2
